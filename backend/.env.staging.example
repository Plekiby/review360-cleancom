# ========================================
# Variables d'environnement — Staging O2switch
# Copier ce fichier en .env et remplir les valeurs
# ========================================

NODE_ENV=staging
PORT=3001

# PostgreSQL (créé via cPanel → Bases de données PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sc1juwa0721_r360staging
DB_USER=sc1juwa0721_r360s
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE

# JWT — générer avec : node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=CHANGER_CE_SECRET_64_CHARS_MINIMUM
JWT_EXPIRES_IN=7d

# CORS — URL du frontend staging
FRONTEND_URL=https://staging.sc1juwa0721.universe.wf
